{
  "name": "btw",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "btw": "dist/index.js",
    "qq": "dist/index.js",
    "q": "dist/index.js"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "btw": "bun src/index.ts",
    "render:sample": "bun src/lib/markdown/sample-renderer.ts",
    "stream:sample": "bun src/lib/markdown/stream-sample.ts",
    "build": "bun build --minify --target node --outdir dist src/index.ts",
    "check": "biome check",
    "check:fix": "biome check --write --unsafe",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "ci": "bun run check && bun run typecheck && bun test && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@justmiracle/result": "^2.0.0",
    "cli-highlight": "^2.1.11",
    "marked": "^18.0.3",
    "picocolors": "^1.1.1",
    "remeda": "^2.34.1",
    "typescript": "6.0.3",
    "valibot": "^1.4.0",
    "wrap-ansi": "^10.0.0",
    "yargs": "^18.0.0"
  }
}
